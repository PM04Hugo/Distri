	public void comision(int compromiso , int pid) {
		//Les envia al resto el número que el tiene
		//Y ellos nos lo envián a nosotros
		//Vemos que número tiene mayoría y lo pasamos a comisiones

	    comisiones[pid] = compromiso;
	    int quorum = 0;
	    procesosComision++;
	    if(procesosComision>numProcesos/2)
	    {
		    for(int i = 0; i < numProcesos; i++) {
		        if (comisiones[i] == 0) continue;
	
		        quorum = 0;
		        for(int j = 0; j < numProcesos; j++) {
		        	if(compromisos[j]==0)
						continue;
					else if (compromisos[j]==comisiones[i]) 
						quorum++;
		        }
	
		        if(quorum >= numProcesos/2) {
					this.vConfirmacion=comisiones[i];
		        	Server.path("confirmacion").queryParam("comision", vConfirmacion).queryParam("pid", this.pid).request().get(); 
		            return;
		        }
		    }
		    if(procesosComision==(numProcesos-1))
		    {
		    	Server.path("confirmacion").queryParam("comision", -1).queryParam("pid", this.pid).request().get();
		    }
	    }
		
		//comision(mayoria);
		
	}
	
